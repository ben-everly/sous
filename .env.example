# Copy to .env.local and fill in with values from:
#   npx supabase start && npx supabase status -o env
# Map: API_URL -> NEXT_PUBLIC_SUPABASE_URL,
# PUBLISHABLE_KEY -> NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service-role key (SECRET_KEY from `npx supabase status -o env`). Read directly
# via process.env in e2e/ only (the test-seeding admin client) — intentionally
# NOT in lib/env.ts, and never imported into app/runtime code.
SUPABASE_SECRET_KEY=

# Google OAuth credentials. Not needed for CI (seeds sessions and never reaches
# Google). Non-empty placeholders keep `supabase start` happy when the enabled
# provider block reads these via env().
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=placeholder
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=placeholder
# GoTrue's Google provider callback. Locally this is the Supabase auth endpoint
# (port 54321), and it must be registered verbatim as an Authorized redirect URI
# on the Google OAuth client. Remote/prod projects set their own callback here.
SUPABASE_AUTH_EXTERNAL_GOOGLE_REDIRECT_URI=http://127.0.0.1:54321/auth/v1/callback
