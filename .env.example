# Copy to .env and fill from `npx supabase start && npx supabase status -o env`:
#   API_URL          -> NEXT_PUBLIC_SUPABASE_URL
#   PUBLISHABLE_KEY  -> NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#   SECRET_KEY       -> SUPABASE_SECRET_KEY
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service-role secret — used only by e2e/ seeding (admin client), deliberately
# kept out of lib/env.ts so it never reaches app/runtime code.
SUPABASE_SECRET_KEY=

# Not used in CI (it seeds sessions, never calls Google). Placeholders must be
# non-empty or `supabase start` fails reading the provider block via env().
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=placeholder
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=placeholder
# Google's OAuth callback — locally the Supabase auth endpoint. Must be registered
# verbatim as an Authorized redirect URI on the Google OAuth client.
SUPABASE_AUTH_EXTERNAL_GOOGLE_REDIRECT_URI=http://127.0.0.1:54321/auth/v1/callback
